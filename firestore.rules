rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'gouthamk@orbitsol.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Insights
    match /insights/{postId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      
      function isValidInsight(data) {
        return data.title is string && data.title.size() <= 256 &&
               data.summary is string && data.summary.size() <= 1024 &&
               data.content is string && data.content.size() <= 50000 &&
               data.status in ['draft', 'published'];
      }

      allow create: if isAdmin() && isValidInsight(request.resource.data);
      allow update: if isAdmin() && isValidInsight(request.resource.data);
      allow delete: if isAdmin();
    }

    // Site Settings
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins - Only admins can manage admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
